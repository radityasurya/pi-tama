    "prompt"
  ],
  "homepage": "https://github.com/kaushikgopal/pi-tama/tree/main/extensions/pi-ask-user#readme",
  "bugs": {
    "url": "https://github.com/kaushikgopal/pi-tama/issues"
  },
  "repository": {
